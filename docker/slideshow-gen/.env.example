# Slideshow Generator — Environment Variables
# Copy to .env and adjust for your host

# Paths (defaults work for local dev)
INPUT_PATH=./input
OUTPUT_PATH=./output
MODELS_PATH=./models

# Hugging Face token (optional, for gated models)
HF_TOKEN=

# Music model override
# CPU options: facebook/musicgen-small, facebook/musicgen-medium
# GPU options: facebook/musicgen-large
MUSICGEN_MODEL=

# GPU variant: video encoding
# Options: h264_nvenc (hardware), libx264 (software fallback)
FFMPEG_ENCODER=h264_nvenc

# CPU thread count (match your P-core count)
NUM_THREADS=12

# Background music volume relative to narration (0.0–1.0)
MUSIC_VOLUME=0.2
