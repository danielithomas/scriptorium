{
  "_comment": "FLUX.2-klein-9B ultrawide (21:9) with 4x upscale. Generates at 1344x576 then upscales to ~5376x2304. POST to http://<host>:8188/prompt with {\"prompt\": <this object>}.",
  "1": {
    "class_type": "UNETLoader",
    "inputs": {
      "unet_name": "flux-2-klein-9b.safetensors",
      "weight_dtype": "default"
    }
  },
  "2": {
    "class_type": "DualCLIPLoader",
    "inputs": {
      "clip_name1": "clip_l.safetensors",
      "clip_name2": "t5xxl_fp8_e4m3fn.safetensors",
      "type": "flux"
    }
  },
  "3": {
    "class_type": "VAELoader",
    "inputs": {
      "vae_name": "ae.safetensors"
    }
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "PROMPT_TEXT",
      "clip": ["2", 0]
    }
  },
  "5": {
    "class_type": "EmptySD3LatentImage",
    "inputs": {
      "width": 1344,
      "height": 576,
      "batch_size": 1
    }
  },
  "6": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["1", 0],
      "positive": ["4", 0],
      "negative": ["7", 0],
      "latent_image": ["5", 0],
      "seed": 0,
      "control_after_generate": "randomize",
      "steps": 20,
      "cfg": 3.5,
      "sampler_name": "euler",
      "scheduler": "simple",
      "denoise": 1.0
    }
  },
  "7": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "",
      "clip": ["2", 0]
    }
  },
  "8": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["6", 0],
      "vae": ["3", 0]
    }
  },
  "9": {
    "class_type": "UpscaleModelLoader",
    "inputs": {
      "model_name": "4x-UltraSharp.pth"
    }
  },
  "10": {
    "class_type": "ImageUpscaleWithModel",
    "inputs": {
      "upscale_model": ["9", 0],
      "image": ["8", 0]
    }
  },
  "11": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["10", 0],
      "filename_prefix": "flux2klein-ultrawide"
    }
  }
}
