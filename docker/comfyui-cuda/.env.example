# ComfyUI CUDA Configuration

# ComfyUI version (git branch/tag)
COMFYUI_VERSION=master

# Host port for web UI and API
COMFYUI_PORT=8188

# Path to shared model directory on the host
# Structure: checkpoints/, clip/, vae/, unet/, loras/, embeddings/, upscaler/
# Can be shared with image-gen-cuda — LoRAs, embeddings, and upscaler are reused
MODELS_PATH=/path/to/your/models

# Output directory — map to a shared directory (SMB, NFS, or local)
# for easy access from orchestrator agents or other machines
OUTPUT_PATH=./output

# GPU selection (default: first GPU)
CUDA_VISIBLE_DEVICES=0
