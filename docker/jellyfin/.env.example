# Jellyfin Media Server — Environment Variables
# Copy to .env and adjust for your host

# Paths
CONFIG_PATH=/data/docker/jellyfin
MEDIA_PATH=/data/media

# Ports (defaults are standard)
JELLYFIN_PORT=8096
JELLYFIN_HTTPS_PORT=8920
BAZARR_PORT=6767

# Timezone
TZ=Australia/Melbourne

# User/group IDs (match your host user: id -u / id -g)
PUID=1000
PGID=1000

# GPU render group (check: getent group render | cut -d: -f3)
RENDER_GROUP=render

# Published server URL (for client connection display)
# Use LAN IP for local access, Tailscale IP for remote
SERVER_URL=http://localhost:8096
